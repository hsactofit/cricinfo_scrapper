# Copy to .env and fill in your values
DB_HOST=localhost
DB_PORT=5432
DB_NAME=krickbiz
DB_USER=himanshu
DB_PASSWORD=admin

# Which machine is this (for progress tracking)
MACHINE_ID=m2_mini

# Chrome version (check yours: chrome://version)
CHROME_VERSION=146

# Parallel browser workers (4 is safe, reduce to 2 on M1 if memory is tight)
WORKERS=4

# Delay between page loads per worker (seconds)
PAGE_DELAY=2
